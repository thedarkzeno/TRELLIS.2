{
    "_comment": "SS Flow — 4 blocks reuse [1,3,3,1] + mixer 2 blocks (dim=768) + mask_ratio=0.5. Designed for RTX 3090 single-GPU training on 1k dataset.",
    "models": {
        "denoiser": {
            "name": "ElasticSparseStructureFlowModel",
            "args": {
                "resolution": 32,
                "in_channels": 32,
                "out_channels": 32,
                "model_channels": 1536,
                "cond_channels": 1024,
                "num_blocks": 14,
                "num_heads": 12,
                "mlp_ratio": 5.3334,
                "pe_mode": "rope",
                "share_mod": true,
                "initialization": "scaled",
                "qk_rms_norm": true,
                "qk_rms_norm_cross": true,
                "repeat_schedule": [
                    1,
                    3,
                    3,
                    3,
                    3,
                    3,
                    3,
                    3,
                    3,
                    3,
                    3,
                    3,
                    3,
                    1
                ],
                "patch_mixer_blocks": 2,
                "patch_mixer_dim": 768
            }
        }
    },
    "dataset": {
        "name": "ImageConditionedSparseStructureLatent",
        "args": {
            "min_aesthetic_score": 0.0,
            "image_size": 512,
            "pretrained_ss_dec": "microsoft/TRELLIS-image-large/ckpts/ss_dec_conv3d_16l8_fp16"
        }
    },
    "trainer": {
        "name": "ImageConditionedFlowMatchingCFGTrainer",
        "args": {
            "max_steps": 30000,
            "batch_size_per_gpu": 8,
            "batch_split": 2,
            "optimizer": {
                "name": "AdamW8bit",
                "args": {
                    "lr": 1e-4,
                    "weight_decay": 0.01,
                    "betas": [0.9, 0.95],
                    "eps": 1e-8
                }
            },
            "ema_rate": [
                0.9999
            ],
            "mix_precision_mode": "amp",
            "mix_precision_dtype": "bfloat16",
            "grad_clip": {
                "name": "AdaptiveGradClipper",
                "args": {
                    "max_norm": 1.0,
                    "clip_percentile": 95
                }
            },
            "i_log": 50,
            "i_sample": 1000,
            "i_save": 1000,
            "snapshot_num_samples": 8,
            "p_uncond": 0.1,
            "t_schedule": {
                "name": "logitNormal",
                "args": {
                    "mean": 1.0,
                    "std": 1.0
                }
            },
            "sigma_min": 1e-5,
            "mask_ratio": 0.5,
            "image_cond_model": {
                "name": "DinoV3FeatureExtractor",
                "args": {
                    "model_name": "facebook/dinov3-vitl16-pretrain-lvd1689m",
                    "image_size": 512
                }
            }
        }
    }
}
